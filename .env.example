OID4VC_BACKEND__SERVER__HOST=0.0.0.0
OID4VC_BACKEND__SERVER__PORT=8080
OID4VC_BACKEND__DATABASE__ADMIN_URL=postgres://postgres:postgres@localhost:5432/openid4vc_admin
OID4VC_BACKEND__DATABASE__MAX_CONNECTIONS=20
OID4VC_BACKEND__REDIS__URL=redis://localhost:6379
OID4VC_BACKEND__SECURITY__JWT_ISSUER=https://auth.example.com
OID4VC_BACKEND__SECURITY__JWT_AUDIENCE=openid4vc-backend
OID4VC_BACKEND__SECURITY__JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
OID4VC_BACKEND__KEY_MANAGEMENT__BACKEND=file
OID4VC_BACKEND__KEY_MANAGEMENT__FILE_BASE_PATH=.keys
OID4VC_BACKEND__KEY_MANAGEMENT__VAULT_ADDR=http://localhost:8200
OID4VC_BACKEND__KEY_MANAGEMENT__VAULT_TOKEN=dev-token
